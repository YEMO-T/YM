# === Supabase ===
SUPABASE_URL="你的_Supabase_URL"
SUPABASE_KEY="你的_Supabase_Key"

# === 大模型提供商选择 ===
# 可选值: deepseek | qianfan | zhipu | moonshot
LLM_PROVIDER="deepseek"

# === DeepSeek 配置 (默认提供商，OpenAI 兼容 API) ===
LLM_API_BASE="https://api.deepseek.com/v1"
LLM_API_KEY="你的_DeepSeek_API_KEY"
LLM_MODEL="deepseek-chat"

# === 百度千帆 / 文心一言 配置 (可选) ===
QIANFAN_AK="你的_千帆_AK"
QIANFAN_SK="你的_千帆_SK"

# === 智谱 GLM 配置 (可选，OpenAI 兼容 API) ===
ZHIPU_API_KEY="你的_智谱_API_KEY"
ZHIPU_MODEL="glm-4-flash"
ZHIPU_API_BASE="https://open.bigmodel.cn/api/paas/v4"

# === Moonshot / Kimi 配置 (可选，OpenAI 兼容 API) ===
MOONSHOT_API_KEY="你的_Moonshot_API_KEY"
MOONSHOT_MODEL="moonshot-v1-8k"
MOONSHOT_API_BASE="https://api.moonshot.cn/v1"

# === 阿里云通义千问 (DashScope) 配置 (可选) ===
DASHSCOPE_API_KEY="你的_阿里云_DashScope_API_KEY"
DASHSCOPE_MODEL="qwen-max"

# === JWT 认证 ===
JWT_SECRET_KEY="your-secret-key-change-in-production"
